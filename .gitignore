__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.DS_Store

# never commit keys or demo artifacts
*.pem
*.cose

# test vectors are FROZEN committed bytes — exempt from the key/artifact ignore
# (negate every ignored extension; vector keys are PEM-encoded TEST-ONLY files)
!test-vectors/**/*.cose
!test-vectors/**/*.pem

# interop artifacts are committed reference outputs (test-only keys, not secrets)
!interop/**/*.cose
!interop/**/*.pem
